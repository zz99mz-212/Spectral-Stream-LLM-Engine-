\title{Unified Tensor-Field Compression via Ergodic Hyperfunctions:\\ 
       Achieving Extreme Parameter Reduction in Large Language Models}
\author{SpectralStream Research \\
        \texttt{https://github.com/anomalyco/SpectralStream}}
\date{\today}

\newtheorem{definition}{Definition}
\newtheorem{theorem}{Theorem}
